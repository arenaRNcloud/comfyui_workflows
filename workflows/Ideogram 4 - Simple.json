e\": \"obj\",\n        \"bbox\": [280, 100, 600, 680],\n        \"desc\": \"an elderly wizard with a long silver beard, wearing deep indigo robes covered in embroidered star patterns and a tall conical hat, hunched over the desk writing with a glowing quill, round brass spectacles perched on his nose, face deeply lined with age\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [640, 280, 820, 500],\n        \"desc\": \"a large mechanical brass orrery on a tripod stand, slowly rotating, showing planets and moons, glowing faintly orange, gears visible\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [60, 480, 260, 880],\n        \"desc\": \"a giant cracked hourglass taller than a man, standing on a stone plinth, the glass cracked with golden light leaking from the crack, dark sand still slowly falling inside\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [390, 240, 540, 400],\n        \"desc\": \"a large jet-black raven perched on the wizard's left shoulder, one eye glowing red, wings slightly spread, looking directly at the viewer\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [700, 620, 980, 900],\n        \"desc\": \"a sleeping orange tabby cat curled on a velvet cushion on the floor next to the desk leg, softly glowing aura around it suggesting magical familiar\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [160, 700, 400, 960],\n        \"desc\": \"a worn leather satchel dropped on the stone floor, buckles open, spilling out more scrolls, a compass, and a small skull\"\n      }\n    ]\n  }\n}"]},{"id":158,"type":"VAELoader","pos":[4936.543548949699,-3099.6043182785766],"size":[470,110],"flags":{},"order":2,"mode":0,"inputs":[{"localized_name":"vae_name","name":"vae_name","type":"COMBO","widget":{"name":"vae_name"},"link":null}],"outputs":[{"localized_name":"VAE","name":"VAE","type":"VAE","links":[232]}],"properties":{"cnr_id":"comfy-core","ver":"0.8.2","Node name f