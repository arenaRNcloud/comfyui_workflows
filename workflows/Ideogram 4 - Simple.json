      "widgets_values": [
        "{\n  \"high_level_description\": \"a wizard sitting at a cluttered apothecary desk inside a lighthouse, surrounded by a raven, a mechanical orrery, a giant cracked hourglass, and a ghostly ship visible through the window\",\n  \"style_description\": {\n    \"aesthetics\": \"painterly, moody\",\n    \"lighting\": \"candlelight interior with moonlight from window\",\n    \"photo\": \"medium shot\",\n    \"medium\": \"oil painting digital render\"\n  },\n  \"compositional_deconstruction\": {\n    \"background\": \"curved stone lighthouse interior walls with iron sconce candles and moss-covered bricks\",\n    \"elements\": [\n      {\n        \"type\": \"obj\",\n        \"bbox\": [0, 0, 1000, 1000],\n        \"desc\": \"curved stone lighthouse interior, dark mossy brick walls, warm candlelight glow, circular room\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [580, 80, 860, 520],\n        \"desc\": \"tall arched window with iron leading, moonlight pouring in, a ghostly translucent ship sails on stormy sea visible outside, waves crashing\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [60, 40, 280, 340],\n        \"desc\": \"tall iron sconce mounted on brick wall holding three dripping tallow candles, warm amber flame, wax drips down the wall\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [100, 300, 900, 720],\n        \"desc\": \"a long cluttered apothecary desk made of dark oak, covered in open leather-bound spell books, ink pots, quill pens, small glass vials of glowing liquid, scattered parchment scrolls\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [280, 100, 600, 680],\n        \"desc\": \"an elderly wizard with a long silver beard, wearing deep indigo robes covered in embroidered star patterns and a tall conical hat, hunched over the desk writing with a glowing quill, round brass spectacles perched on his nose, face deeply lined with age\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [640, 280, 820, 500],\n        \"desc\": \"a large mechanical brass orrery on a tripod stand, slowly rotating, showing planets and moons, glowing faintly orange, gears visible\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [60, 480, 260, 880],\n        \"desc\": \"a giant cracked hourglass taller than a man, standing on a stone plinth, the glass cracked with golden light leaking from the crack, dark sand still slowly falling inside\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [390, 240, 540, 400],\n        \"desc\": \"a large jet-black raven perched on the wizard's left shoulder, one eye glowing red, wings slightly spread, looking directly at the viewer\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [700, 620, 980, 900],\n        \"desc\": \"a sleeping orange tabby cat curled on a velvet cushion on the floor next to the desk leg, softly glowing aura around it suggesting magical familiar\"\n      },\n      {\n        \"type\": \"obj\",\n        \"bbox\": [160, 700, 400, 960],\n        \"desc\": \"a worn leather satchel dropped on the stone floor, buckles open, spilling out more scrolls, a compass, and a small skull\"\n      }\n    ]\n  }\n}"
